{
  "name": "photo-space",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cli": "pnpm --filter photospace-cli dev",
    "build:cli": "pnpm --filter photospace-cli build",
    "build:runtime": "pnpm --filter photospace-runtime build",
    "test": "node --experimental-strip-types --test packages/*/test/*.test.ts src/*/*.test.ts",
    "typecheck": "pnpm -r --include-workspace-root exec tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "photospace-core": "workspace:*",
    "photospace-runtime": "workspace:*",
    "three": "^0.185.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "overrides": {
      "sharp": "^0.35.3"
    }
  }
}
