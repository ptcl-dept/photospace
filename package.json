{
  "name": "photo-space",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "photospace": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cli": "node --experimental-strip-types src/cli/index.ts",
    "build:runtime": "pnpm --filter photospace-runtime build"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "onnxruntime-node": "^1.27.0",
    "photospace-runtime": "workspace:*",
    "sharp": "^0.35.3",
    "three": "^0.185.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "overrides": {
      "sharp": "^0.35.3"
    }
  }
}
