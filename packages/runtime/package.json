{
  "name": "photospace-runtime",
  "version": "0.1.0",
  "description": "Photospace package loader — select a decodable photo candidate, decode depth/mask/normal, and recover world-space positions.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ptcl-dept/photospace.git",
    "directory": "packages/runtime"
  },
  "keywords": ["photo-space", "depth", "webgl", "three.js"],
  "main": "./dist/loader.js",
  "module": "./dist/loader.js",
  "types": "./dist/loader.d.ts",
  "exports": {
    ".": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup loader.ts --format esm --out-dir dist --clean && tsc -p tsconfig.json --outDir dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
