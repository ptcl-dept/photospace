{
  "name": "photospace-cli",
  "version": "0.2.0",
  "description": "Photospace CLI — batch-bake packages of photo candidates plus depth.png/meta.json (and optional mask/normal maps).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ptcl-dept/photospace.git",
    "directory": "packages/cli"
  },
  "bin": {
    "photospace": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "node --experimental-strip-types src/index.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "onnxruntime-node": "^1.27.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "photospace-core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2"
  }
}
